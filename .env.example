# Copy to .env and pick ONE preset below. .env is gitignored.
# Read in inference.py (lines ~33-40): API_BASE_URL, MODEL_NAME, HF_TOKEN.

# ---- Preset A: Local LLM (FREE, recommended for dev) ----------------------
# Works with any OpenAI-compatible local server: llama.cpp, LM Studio, Ollama.
# HF_TOKEN is optional when API_BASE_URL points at localhost / 0.0.0.0 / 127.0.0.1.
# MODEL_NAME is auto-discovered from {API_BASE_URL}/models if left blank.
API_BASE_URL=http://0.0.0.0:1337/v1
# MODEL_NAME=

# ---- Preset B: HF Inference Router — cheapest model (~$0.05 / 1M tok) -----
# Recommended for the final eval run (~$0.35 for 100 episodes).
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
# HF_TOKEN=hf_xxx

# ---- Preset C: HF Inference Router — stronger model (~$0.20 / 1M tok) -----
# Showcase / leaderboard run (~$1.40 for 100 episodes).
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
# HF_TOKEN=hf_xxx

# ---- Optional ---------------------------------------------------------------
# IMAGE_NAME=         # If set, inference.py spins up the env via Docker
# ENV_BASE_URL=       # Defaults to http://localhost:8000 (the local FastAPI server)
# MAX_STEPS=30        # Episode length cap (TASK_HORIZON minimum unless ALLOW_SHORT_EPISODE=1)
# ALLOW_SHORT_EPISODE=0
